# Discord webhook for stock alerts. Required.
# Get one from your Discord server: Channel Settings → Integrations → Webhooks → New
DISCORD_WEBHOOK_URL=

# Path to the SQLite database file. Optional. Defaults to data/data.db
# DATABASE_PATH=data/data.db

# Comma-separated proxy list. Optional. Format: user:pass@host:port (one per line in env, comma-separated values)
# Used to spread Best Buy API requests across IPs if rate-limited. Leave empty for direct.
# BESTBUY_PROXIES=

# Residential proxy for the headless PDP fallback. Format: host:port or host:port:user:pass.
# When wired into the worker, SKUs that BB's legacy priceBlocks index doesn't recognize get
# stock + price from a Playwright/stealth scrape of the live PDP. Without this set the
# headless path is disabled and metadata-only items keep null price/stock until added manually.
# BB_PROXY=

# Worker version string surfaced in /api/health (purely informational).
WORKER_VERSION=v1.0.0

# Port for Next.js dev server. Optional, defaults to 3000.
# PORT=3000
